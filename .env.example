# Active Spring profile
SPRING_PROFILES_ACTIVE=dev

# IP intelligence provider configuration
# Available providers: mock, proxycheck
IP_INTELLIGENCE_PROVIDER=proxycheck
IP_INTELLIGENCE_BASE_URL=https://proxycheck.io/v2
IP_INTELLIGENCE_API_KEY=your_api_key_here
IP_INTELLIGENCE_CACHE_DURATION_MINUTES=60

# PostgreSQL configuration
# Used when SPRING_PROFILES_ACTIVE=postgres
POSTGRES_DB_URL=jdbc:postgresql://localhost:5432/ip_check_db
POSTGRES_DB_USERNAME=postgres
POSTGRES_DB_PASSWORD=postgres